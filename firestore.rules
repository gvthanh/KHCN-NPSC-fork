
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hàm tiện ích kiểm tra đăng nhập
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Kho sáng kiến (Chính thức)
    match /initiatives/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Sub-collection cho tài liệu tham khảo
    match /initiatives/{parentId}/{subCol}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 2. Danh mục đề tài KHCN
    match /research_projects/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 3. Cấu hình hệ thống
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 4. Sáng kiến chờ duyệt (cho phép tạo không cần login)
    match /pending_initiatives/{docId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // 5. Hồ sơ người dùng
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
